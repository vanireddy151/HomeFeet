{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://landsdevelop25.onrender.com/api/:path*"
    },
    {
      "source": "/share/property/:id",
      "destination": "https://landsdevelop25.onrender.com/share/property/:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
